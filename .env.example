# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# ── Dataset input / run-output roots ────────────────────────────────────────
# Override the hardcoded defaults in the code. Read by
# indexing_corpus_dataset.layout (which loads .env itself), so they take effect
# for every entry point — including non-interactive SLURM jobs where ~/.bashrc
# is not sourced. A real exported env var (shell/sbatch) still wins over .env.
DRA_DATA_ROOT=/projects/0/prjs0834/heydars/DRA_training/data
DRA_OUTPUT_ROOT=/projects/0/prjs0834/heydars/DRA_training/run_outputs

# ── DrTULU web-tool API keys ────────────────────────────────────────────────
# Loaded automatically via load_dotenv() in experiments/dra_inference.py.
# Only the DrTULU agent's web tools read these; other agents ignore them.

TAVILY_API_KEY=   # google_search fallback  — https://app.tavily.com/
SERPER_API_KEY=   # google_search (primary) — https://serper.dev/
S2_API_KEY=       # snippet_search          — https://api.semanticscholar.org/
JINA_API_KEY=     # browse_webpage          — https://jina.ai/reader/
